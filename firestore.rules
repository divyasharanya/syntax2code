rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isCompany() {
      return isSignedIn() && getUserRole() == 'company';
    }

    // Admin check is purely email-based via the Firebase Auth JWT token.
    // This avoids any dependency on the Firestore `role` field for the admin user,
    // which may be null on first login. Update this email to match VITE_ADMIN_EMAIL.
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'divyasaranya0619@gmail.com';
    }

    // ── users/{uid} ────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn() || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── tasks/{taskId} ─────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if true;
      allow create: if isCompany() || isAdmin();
      allow update: if isSignedIn() && (
        // Company owner or admin may update any field on their task.
        resource.data.companyId == request.auth.uid || isAdmin()
        ||
        // Any signed-in user (e.g. a candidate submitting work) may increment
        // applicantsCount — but ONLY that field, nothing else.
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['applicantsCount'])
      );
      allow delete: if isSignedIn() && (
        resource.data.companyId == request.auth.uid || isAdmin()
      );
    }

    // ── applications/{appId} ───────────────────────────────────────────────
    match /applications/{appId} {
      allow create: if isSignedIn() &&
        request.resource.data.candidateId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.candidateId == request.auth.uid ||
        resource.data.companyId == request.auth.uid ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.companyId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
      // Admin list access: allow listing the entire collection
      allow list: if isAdmin();
    }

    // ── submissions/{subId} ────────────────────────────────────────────────
    match /submissions/{subId} {
      allow create: if isSignedIn() &&
        request.resource.data.candidateId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.candidateId == request.auth.uid ||
        resource.data.companyId == request.auth.uid ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.companyId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
      // Admin list access: allow listing the entire collection
      allow list: if isAdmin();
    }
  }
}
