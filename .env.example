# Environment variables for MicroIntern
# Copy this file to .env and fill in real values. Never commit .env to git.

# ── Cloudinary (unsigned upload for submission files) ──────────────────────
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# ── Admin access ────────────────────────────────────────────────────────────
# Any Firebase Auth user whose email matches this is treated as role:"admin"
VITE_ADMIN_EMAIL=your-admin-email@example.com
